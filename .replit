modules = ["nix"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Ejecutar tarea1"

[[workflows.workflow]]
name = "Ejecutar tarea1"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc tdas/*.c tarea1.c -Wno-unused-result -o tarea1 && ./tarea1"

[workflows.workflow.metadata]
outputType = "console"
